APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Identifier baked into the hook installer (token dir, env var, codex markers).
# Defaults to a slugified APP_NAME. Must be a valid shell identifier.
# HOOK_NAMESPACE=token_slayer

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="reverb"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="localhost"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local
# Queue runs on redis; the `worker` container consumes it (php artisan queue:work redis).
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_SCHEME=tcp
# In Docker (dev/staging compose), set REDIS_HOST=redis — the valkey service name.
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Slack app used for "Login with Slack" (OAuth via Socialite)
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_REDIRECT_URI="${APP_URL}/auth/slack/callback"
# Bot User OAuth Token (xoxb-…) with the users:read scope; used to read members'
# Slack display names via users.info (battlefield names + slack:backfill-display-names).
SLACK_BOT_TOKEN=

# Separate Slack app used to post boss-fight notifications (incoming webhook)
SLACK_NOTIFIER_WEBHOOK_URL=

# Slack app used to post org-account token-reject security alerts via the Web API.
# Bot User OAuth Token (xoxb-…) with the chat:write scope; the bot must be a
# member of the target channel. SLACK_SECURITY_CHANNEL is a channel id (C…) or #name.
SLACK_SECURITY_BOT_TOKEN=
SLACK_SECURITY_CHANNEL=
